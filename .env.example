INFOR_APP_NAME=Infor Hub API
INFOR_APP_ENV=local

COLLECTOR_MODEL=openai:gpt-4o
COLLECTOR_WORKSPACE=.collector_workspace

INFOR_OUTPUT_DIR=outputs
INFOR_LOG_DIR=.logs
INFOR_TASK_DIR=outputs/tasks
INFOR_SOURCE_REGISTRY=configs/source_registry.json

INFOR_TIME_WINDOW_DAYS=90
INFOR_MAX_SOURCES_PER_TASK=100
